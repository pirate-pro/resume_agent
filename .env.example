APP_NAME=resume-agent
APP_ENV=dev
APP_DEBUG=true
APP_LOG_LEVEL=INFO
API_PREFIX=/api/v1

LLM_ENABLED=true
LLM_BASE_URL=http://199.199.199.60/v1
LLM_API_KEY=replace-with-your-gpustack-key
LLM_MODEL_NAME=qwen3.5-27b-w8a8-mtp
LLM_TEMPERATURE=0.1

POSTGRES_DSN=postgresql+psycopg://postgres:postgres@localhost:54329/resume_agent
SQLALCHEMY_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

MAX_UPLOAD_SIZE_MB=20
OCR_ENABLED=false
OCR_PROVIDER=mineru
OCR_BASE_URL=http://199.199.199.106:8000
RESUME_PARSE_TIMEOUT_SEC=60
FILE_ROOT_DIR=./data
ARTIFACT_ROOT_DIR=./data/tasks

TOP_K=20
VECTOR_RECALL_K=50
KEYWORD_RECALL_K=50
SCORE_WEIGHT_SKILL=0.35
SCORE_WEIGHT_EXPERIENCE=0.25
SCORE_WEIGHT_PROJECT=0.20
SCORE_WEIGHT_EDUCATION=0.10
SCORE_WEIGHT_PREFERENCE=0.10
TASK_MAX_RETRIES=2
TASK_STAGE_TIMEOUT_SEC=180
TASK_LOCK_TIMEOUT_SEC=600
TASK_WORKER_POLL_INTERVAL_SEC=2

CORS_ORIGINS=http://localhost:3000,http://localhost:5173
RATE_LIMIT_ENABLED=false
REQUEST_ID_ENABLED=true
AUDIT_LOG_ENABLED=true

AUTH_ENABLED=false
JWT_SECRET=dev-secret
JWT_ALGORITHM=HS256
ADMIN_TOKEN=admin-token

AUTO_SEED_JOBS=true
